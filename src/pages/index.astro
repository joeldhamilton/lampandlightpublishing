---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Lamp & Light Publishing — books that sharpen, convict, and equip. Classic adaptations, devotionals, and biblical study by Joel Hamilton." />
    <link rel="icon" type="image/png" href={`${base}images/lamplight-icon.png`} />
    <title>Lamp & Light Publishing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav">
      <div class="nav-inner">
        <a href={base} class="nav-brand">Lamp & Light</a>
        <div class="nav-right">
          <a href="#books">Books</a>
          <a href="#classics">Classics</a>
          <a href="#about">About</a>
          <button class="theme-toggle" aria-label="Toggle light/dark mode" id="theme-toggle">
            <span class="theme-icon sun">&#9788;</span>
            <span class="theme-icon moon">&#9790;</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-glow-2"></div>
      <div class="hero-inner">
        <div class="lamp-icon">
          <svg viewBox="0 0 64 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="lamp-svg">
            <path d="M28 8C28 5 32 2 32 2S36 5 36 8C36 12 34 14 34 14H30C30 14 28 12 28 8Z" fill="url(#flame)" class="flame"/>
            <rect x="29" y="14" width="6" height="4" rx="1" fill="#c87020"/>
            <path d="M24 18H40L42 28H22L24 18Z" fill="#8b5e3c" stroke="#a0703c" stroke-width="0.5"/>
            <rect x="22" y="28" width="20" height="3" rx="1" fill="#a0703c"/>
            <path d="M26 31H38V50C38 52 36 54 34 54H30C28 54 26 52 26 50V31Z" fill="#7a4a28" stroke="#8b5e3c" stroke-width="0.5"/>
            <rect x="24" y="54" width="16" height="3" rx="1" fill="#a0703c"/>
            <rect x="22" y="57" width="20" height="2" rx="1" fill="#8b5e3c"/>
            <path d="M18 59H46V62C46 63 45 64 44 64H20C19 64 18 63 18 62V59Z" fill="#6b3a1a"/>
            <defs>
              <radialGradient id="flame" cx="0.5" cy="0.3" r="0.7">
                <stop offset="0%" stop-color="#fff4d4"/>
                <stop offset="30%" stop-color="#ffb833"/>
                <stop offset="70%" stop-color="#e87a10"/>
                <stop offset="100%" stop-color="#c44a00"/>
              </radialGradient>
            </defs>
          </svg>
        </div>
        <p class="hero-label">A Publishing House by Joel Hamilton</p>
        <h1>Lamp &<br/>Light</h1>
        <div class="hero-line"></div>
        <p class="hero-verse">"Your word is a lamp to my feet<br/>and a light to my path."</p>
        <p class="hero-cite">Psalm 119:105</p>
        <div class="hero-ctas">
          <a href="#books" class="btn btn-primary">Browse Books</a>
          <a href="#classics" class="btn btn-outline">Classics Collection</a>
        </div>
      </div>
      <div class="hero-fade"></div>
    </section>

    <!-- Original Books -->
    <section class="section" id="books">
      <div class="container">
        <p class="section-label">Original Works</p>
        <h2 class="section-title">Books</h2>
        <div class="section-line"></div>

        <div class="books-grid">
          <a href="https://amzn.to/42egs57" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover-wrap">
              <div class="book-glow"></div>
              <img src={`${base}images/cover-daily-crusader.jpg`} alt="The Daily Crusader" />
            </div>
            <div class="book-info">
              <p class="book-label">Daily Devotional</p>
              <h3>The Daily Crusader</h3>
              <p class="book-subtitle">365 Days of Faith, Discipline, and War</p>
              <p class="book-desc">A daily devotional for men who take their faith seriously. 365 entries rooted in Scripture — short, direct, built to sharpen.</p>
              <span class="book-link">Get on Amazon &rarr;</span>
            </div>
          </a>

          <a href="https://amzn.to/4mwc8rf" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover-wrap">
              <div class="book-glow"></div>
              <img src={`${base}images/cover-not-by-effort.jpg`} alt="Not by Effort" />
            </div>
            <div class="book-info">
              <p class="book-label">Biblical Study</p>
              <h3>Not by Effort</h3>
              <p class="book-subtitle">How God Grows the Fruit of the Spirit in You</p>
              <p class="book-desc">The fruit of the Spirit is not a checklist. It grows by the work of God, not the effort of man.</p>
              <span class="book-link">Get on Amazon &rarr;</span>
            </div>
          </a>

          <a href="https://amzn.to/4cJAPND" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover-wrap">
              <div class="book-glow"></div>
              <img src={`${base}images/cover-the-line.jpg`} alt="The Line" />
            </div>
            <div class="book-info">
              <p class="book-label">Commitment</p>
              <h3>The Line</h3>
              <p class="book-subtitle">How Total Commitment Transforms Everything</p>
              <p class="book-desc">You've been half-in long enough. What happens when you stop negotiating with yourself and finally commit.</p>
              <span class="book-link">Get on Amazon &rarr;</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Classics -->
    <section class="section section-alt" id="classics">
      <div class="container">
        <p class="section-label">Lamp & Light Classics</p>
        <h2 class="section-title">Classic Literature, Reimagined</h2>
        <div class="section-line"></div>
        <p class="classics-intro">
          The great books deserve to be read — not just remembered. We bring timeless literature to every reading level:
          early readers, modern adaptations, annotated scholar's editions, and homeschool workbooks.
        </p>

        <div class="series-header">
          <h3 class="series-title">Treasure Island</h3>
          <p class="series-author">Robert Louis Stevenson</p>
        </div>

        <p class="edition-label">Reading Editions</p>
        <div class="classics-grid">
          <a href="https://amzn.to/484fX14" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-early-reader.png`} alt="Treasure Island Early Reader" />
            </div>
            <div class="classic-info">
              <h4>Early Reader</h4>
              <p>Ages 6-8</p>
            </div>
          </a>

          <a href="https://amzn.to/4tirXEI" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-modern-classic.png`} alt="Treasure Island Modern Classic" />
            </div>
            <div class="classic-info">
              <h4>Modern Classic</h4>
              <p>Modern English</p>
            </div>
          </a>

          <a href="https://amzn.to/4cszCcw" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-scholars.jpg`} alt="Treasure Island Scholar's Edition" />
            </div>
            <div class="classic-info">
              <h4>Scholar's Edition</h4>
              <p>Annotated Original</p>
            </div>
          </a>
        </div>

        <p class="edition-label">Workbooks</p>
        <div class="classics-grid">
          <a href="https://amzn.to/4tJ0pIj" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-wb-elementary.jpg`} alt="Elementary Workbook" />
            </div>
            <div class="classic-info">
              <h4>Elementary</h4>
              <p>Grades 1-4</p>
            </div>
          </a>

          <a href="https://amzn.to/4myxggK" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-wb-middle.jpg`} alt="Middle Grade Workbook" />
            </div>
            <div class="classic-info">
              <h4>Middle Grade</h4>
              <p>Grades 5-8</p>
            </div>
          </a>

          <a href="https://amzn.to/3QcM9sX" target="_blank" rel="noopener" class="classic-card">
            <div class="classic-cover-wrap">
              <img src={`${base}images/cover-ti-wb-high.jpg`} alt="High School Workbook" />
            </div>
            <div class="classic-info">
              <h4>High School</h4>
              <p>Grades 9-12</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="section" id="about">
      <div class="container">
        <div class="about-content">
          <p class="section-label">About the House</p>
          <h2 class="section-title">About</h2>
          <div class="section-line"></div>
          <p>
            Lamp & Light Publishing is the imprint of <a href="https://www.joelhamilton.com" target="_blank" rel="noopener">Joel Hamilton</a> —
            author, homeschooling father, and founder of <a href="https://www.thenarrowmarch.com" target="_blank" rel="noopener">The Narrow March</a>.
          </p>
          <p>
            We publish books that sharpen, convict, and equip — not books that sit unread on a shelf.
            From daily devotionals to classic literature adaptations to homeschool curriculum,
            everything under this lamp is written to be used, not just owned.
          </p>
          <p>
            Our Classics line brings great literature to every reading level — because the books that shaped civilization
            deserve better than a dusty shelf and a vague memory from high school.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <p class="footer-name">Lamp & Light Publishing</p>
            <p class="footer-tagline">"Your word is a lamp to my feet<br/>and a light to my path."</p>
          </div>
          <div class="footer-nav">
            <h4>Links</h4>
            <a href="https://www.joelhamilton.com" target="_blank" rel="noopener">Joel Hamilton</a>
            <a href="https://www.thenarrowmarch.com" target="_blank" rel="noopener">The Narrow March</a>
            <a href="https://www.donenegotiating.com" target="_blank" rel="noopener">Done Negotiating</a>
          </div>
          <div class="footer-nav">
            <h4>Connect</h4>
            <a href="https://www.instagram.com/joeldhamilton" target="_blank" rel="noopener">Instagram</a>
            <a href="https://x.com/joelhamilton" target="_blank" rel="noopener">X</a>
            <a href="https://www.youtube.com/@joeldhamilton" target="_blank" rel="noopener">YouTube</a>
          </div>
        </div>
        <div class="footer-divider"></div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Lamp & Light Publishing. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      toggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

  </body>
</html>

<style>
  /* ===== Reset & Variables ===== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --font-heading: 'Cormorant Garamond', serif;
    --font-body: 'Inter', sans-serif;
  }

  [data-theme="light"] {
    --bg: #f0ecf5;
    --bg-alt: #e5e0ee;
    --bg-deep: #1a1040;
    --text: #1a1040;
    --text-muted: #5a5070;
    --accent: #e8921a;
    --accent-hover: #f0a030;
    --accent-glow: rgba(232, 146, 26, 0.2);
    --border: #c8c0d8;
    --card-bg: #faf8ff;
    --card-shadow: 0 4px 24px rgba(26, 16, 64, 0.08);
    --nav-bg: rgba(240, 236, 245, 0.95);
    --glow-color: rgba(255, 180, 50, 0.25);
    --purple: #3a2080;
    --purple-muted: rgba(58, 32, 128, 0.08);
  }

  [data-theme="dark"] {
    --bg: #0e0a1a;
    --bg-alt: #140f24;
    --bg-deep: #0a0714;
    --text: #e0dae8;
    --text-muted: #8a80a0;
    --accent: #e8921a;
    --accent-hover: #f0a838;
    --accent-glow: rgba(232, 146, 26, 0.25);
    --border: #2a2240;
    --card-bg: #16112a;
    --card-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
    --nav-bg: rgba(14, 10, 26, 0.95);
    --glow-color: rgba(255, 160, 40, 0.15);
    --purple: #6a50c0;
    --purple-muted: rgba(106, 80, 192, 0.1);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    transition: background 0.3s, color 0.3s;
  }

  a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
  a:hover { color: var(--accent-hover); }

  h1, h2, h3, h4 { font-family: var(--font-heading); line-height: 1.2; }
  img { max-width: 100%; height: auto; }

  /* ===== Nav ===== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-bg); backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 0.75rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-brand {
    font-family: var(--font-heading); font-size: 1.3rem; font-weight: 700;
    color: var(--text);
  }
  .nav-brand:hover { color: var(--accent); }
  .nav-right { display: flex; align-items: center; gap: 1.75rem; }
  .nav-right a {
    color: var(--text-muted); font-size: 0.8rem; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .nav-right a:hover { color: var(--accent); }

  .theme-toggle {
    background: none; border: 1px solid var(--border); border-radius: 50%;
    width: 34px; height: 34px; cursor: pointer; display: flex;
    align-items: center; justify-content: center; font-size: 1rem; color: var(--text);
    transition: border-color 0.2s;
  }
  .theme-toggle:hover { border-color: var(--accent); }
  [data-theme="light"] .moon { display: none; }
  [data-theme="dark"] .sun { display: none; }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-deep);
  }

  .hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(232, 146, 26, 0.3) 0%, rgba(232, 146, 26, 0.08) 40%, transparent 70%);
    pointer-events: none;
    animation: pulse 4s ease-in-out infinite;
  }

  .hero-glow-2 {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(106, 80, 192, 0.2) 0%, transparent 60%);
    pointer-events: none;
    animation: pulse 6s ease-in-out infinite reverse;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
    50% { opacity: 1; transform: translateX(-50%) scale(1.05); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
  }

  .lamp-icon {
    margin-bottom: 2rem;
  }

  .lamp-svg {
    width: 60px;
    height: 75px;
    filter: drop-shadow(0 0 20px rgba(232, 146, 26, 0.6)) drop-shadow(0 0 40px rgba(232, 146, 26, 0.3));
  }

  .flame {
    animation: flicker 2s ease-in-out infinite;
  }

  @keyframes flicker {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    25% { opacity: 0.9; transform: scaleY(0.97); }
    50% { opacity: 1; transform: scaleY(1.02); }
    75% { opacity: 0.95; transform: scaleY(0.99); }
  }

  .hero-label {
    font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(224, 218, 232, 0.6); margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 5rem; font-weight: 700; color: #fff;
    letter-spacing: 0.02em; margin-bottom: 1.5rem;
    text-shadow: 0 0 60px rgba(232, 146, 26, 0.2);
  }

  .hero-line {
    width: 80px; height: 2px; margin: 0 auto 2rem;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }

  .hero-verse {
    font-family: var(--font-heading);
    font-style: italic; font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.7); line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .hero-cite {
    font-size: 0.85rem; color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 3rem; display: block;
  }

  .hero-ctas {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
  }

  .hero-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 150px;
    background: linear-gradient(to bottom, transparent, var(--bg));
    pointer-events: none;
    z-index: 2;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-block; padding: 0.9rem 2.2rem;
    font-family: var(--font-heading); font-size: 0.9rem; font-weight: 700;
    letter-spacing: 0.04em; border: none; cursor: pointer;
    transition: all 0.25s;
  }
  .btn-primary {
    background: var(--accent); color: #fff;
    box-shadow: 0 4px 20px var(--accent-glow);
  }
  .btn-primary:hover {
    background: var(--accent-hover); color: #fff;
    transform: translateY(-2px); box-shadow: 0 8px 30px var(--accent-glow);
  }
  .btn-outline {
    background: transparent; color: rgba(255,255,255,0.8);
    border: 2px solid rgba(255,255,255,0.3);
  }
  .btn-outline:hover {
    background: rgba(255,255,255,0.1); color: #fff;
    border-color: rgba(255,255,255,0.5); transform: translateY(-2px);
  }

  /* ===== Sections ===== */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .section { padding: 6rem 0; }
  .section-alt { background: var(--bg-alt); }
  .section-label {
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--accent); font-weight: 600; margin-bottom: 0.5rem;
  }
  .section-title { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .section-line {
    width: 60px; height: 2px; margin-bottom: 2.5rem;
    background: linear-gradient(90deg, var(--accent), var(--purple));
  }

  /* ===== Book Cards ===== */
  .books-grid { display: flex; flex-direction: column; gap: 3rem; }

  .book-card {
    display: grid; grid-template-columns: 200px 1fr; gap: 3rem; align-items: center;
    background: var(--card-bg); border: 1px solid var(--border); padding: 2.5rem;
    box-shadow: var(--card-shadow); color: var(--text);
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    position: relative; overflow: hidden;
  }

  .book-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--purple));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .book-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    color: var(--text);
  }

  .book-card:hover::before { opacity: 1; }

  .book-cover-wrap {
    position: relative;
  }

  .book-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(circle, var(--accent-glow), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .book-card:hover .book-glow { opacity: 1; }

  .book-cover-wrap img {
    position: relative;
    width: 100%;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    transition: transform 0.3s;
  }

  .book-card:hover .book-cover-wrap img {
    transform: scale(1.02);
  }

  .book-label {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); font-weight: 600; margin-bottom: 0.5rem;
  }
  .book-info h3 { font-size: 1.6rem; margin-bottom: 0.25rem; }
  .book-subtitle {
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--purple); font-weight: 600; margin-bottom: 1rem;
  }
  [data-theme="dark"] .book-subtitle { color: var(--accent); opacity: 0.7; }
  .book-desc { color: var(--text-muted); line-height: 1.8; margin-bottom: 1.25rem; font-size: 0.95rem; }
  .book-link {
    color: var(--accent); font-weight: 600; font-size: 0.9rem;
    transition: letter-spacing 0.2s;
  }
  .book-card:hover .book-link { letter-spacing: 0.04em; }

  /* ===== Classics ===== */
  .classics-intro {
    color: var(--text-muted); font-size: 1.05rem; line-height: 1.9;
    max-width: 700px; margin-bottom: 3rem;
  }

  .series-header {
    margin-bottom: 2.5rem;
    padding: 2rem;
    background: var(--purple-muted);
    border-left: 4px solid var(--purple);
  }
  .series-title { font-size: 2rem; margin-bottom: 0.25rem; }
  .series-author { color: var(--text-muted); font-style: italic; font-size: 1rem; }

  .edition-label {
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--accent); font-weight: 600; margin-bottom: 1.5rem;
  }

  .classics-grid {
