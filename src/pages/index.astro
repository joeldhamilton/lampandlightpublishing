---

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Lamp & Light Publishing — books that sharpen, convict, and equip. Classic adaptations, devotionals, and biblical study by Joel Hamilton." />
    <link rel="icon" type="image/png" href="/images/lamplight-icon.png" />
    <title>Lamp & Light Publishing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700&family=Source+Serif+4:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <img src="/images/lamplight-icon.png" alt="" class="nav-icon" />
          Lamp & Light
        </a>
        <div class="nav-right">
          <a href="#books">Books</a>
          <a href="#classics">Classics</a>
          <a href="#about">About</a>
          <button class="theme-toggle" aria-label="Toggle light/dark mode" id="theme-toggle">
            <span class="theme-icon sun">&#9788;</span>
            <span class="theme-icon moon">&#9790;</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-lamp">&#128294;</div>
        <p class="hero-label">A Publishing House by Joel Hamilton</p>
        <h1>Lamp & Light<br/>Publishing</h1>
        <div class="hero-line"></div>
        <p class="hero-tagline">"Your word is a lamp to my feet and a light to my path."<br/><span class="hero-cite">— Psalm 119:105</span></p>
      </div>
    </section>

    <!-- Original Books -->
    <section class="section" id="books">
      <div class="container">
        <p class="section-label">Original Works</p>
        <h2 class="section-title">Books</h2>
        <div class="section-line"></div>

        <div class="books-grid">
          <a href="https://amzn.to/42egs57" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover">
              <img src="/images/cover-daily-crusader.jpg" alt="The Daily Crusader" />
            </div>
            <div class="book-info">
              <h3>The Daily Crusader</h3>
              <p class="book-subtitle">365 Days of Faith, Discipline, and War</p>
              <p>A daily devotional for men who take their faith seriously. 365 entries rooted in Scripture — short, direct, built to sharpen.</p>
              <span class="book-link">Available on Amazon &rarr;</span>
            </div>
          </a>

          <a href="https://amzn.to/4mwc8rf" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover">
              <img src="/images/cover-not-by-effort.jpg" alt="Not by Effort" />
            </div>
            <div class="book-info">
              <h3>Not by Effort</h3>
              <p class="book-subtitle">How God Grows the Fruit of the Spirit in You</p>
              <p>The fruit of the Spirit is not a checklist. It grows by the work of God, not the effort of man.</p>
              <span class="book-link">Available on Amazon &rarr;</span>
            </div>
          </a>

          <a href="https://amzn.to/4cJAPND" target="_blank" rel="noopener" class="book-card">
            <div class="book-cover">
              <img src="/images/cover-the-line.jpg" alt="The Line" />
            </div>
            <div class="book-info">
              <h3>The Line</h3>
              <p class="book-subtitle">How Total Commitment Transforms Everything</p>
              <p>You've been half-in long enough. This book is about what happens when you stop negotiating with yourself and finally commit.</p>
              <span class="book-link">Available on Amazon &rarr;</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Classics -->
    <section class="section section-alt" id="classics">
      <div class="container">
        <p class="section-label">Lamp & Light Classics</p>
        <h2 class="section-title">Classic Literature, Reimagined</h2>
        <div class="section-line"></div>
        <p class="classics-intro">
          The great books deserve to be read — not just remembered. Lamp & Light Classics brings timeless literature to every reading level:
          early readers, modern English adaptations, annotated scholar's editions, and homeschool workbooks.
        </p>

        <h3 class="series-title">Treasure Island <span class="series-author">Robert Louis Stevenson</span></h3>

        <div class="classics-grid">
          <a href="https://amzn.to/484fX14" target="_blank" rel="noopener" class="classic-card">
            <img src="/images/cover-ti-early-reader.png" alt="Treasure Island Early Reader" />
            <h4>Early Reader</h4>
            <p>Ages 6-8</p>
          </a>

          <a href="https://amzn.to/4tirXEI" target="_blank" rel="noopener" class="classic-card">
            <img src="/images/cover-ti-modern-classic.png" alt="Treasure Island Modern Classic" />
            <h4>Modern Classic</h4>
            <p>Adapted for modern English</p>
          </a>

          <a href="https://amzn.to/4cszCcw" target="_blank" rel="noopener" class="classic-card">
            <img src="/images/cover-ti-scholars.jpg" alt="Treasure Island Scholar's Edition" />
            <h4>Scholar's Edition</h4>
            <p>Annotated original text</p>
          </a>
        </div>

        <h4 class="workbooks-heading">Workbooks</h4>

        <div class="workbooks-grid">
          <a href="https://amzn.to/4tJ0pIj" target="_blank" rel="noopener" class="workbook-card">
            <img src="/images/cover-ti-wb-elementary.jpg" alt="Elementary Workbook" />
            <h4>Elementary</h4>
            <p>Grades 1-4</p>
          </a>

          <a href="https://amzn.to/4myxggK" target="_blank" rel="noopener" class="workbook-card">
            <img src="/images/cover-ti-wb-middle.jpg" alt="Middle Grade Workbook" />
            <h4>Middle Grade</h4>
            <p>Grades 5-8</p>
          </a>

          <a href="https://amzn.to/3QcM9sX" target="_blank" rel="noopener" class="workbook-card">
            <img src="/images/cover-ti-wb-high.jpg" alt="High School Workbook" />
            <h4>High School</h4>
            <p>Grades 9-12</p>
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="section" id="about">
      <div class="container">
        <div class="about-content">
          <div class="section-line"></div>
          <h2>About</h2>
          <p>
            Lamp & Light Publishing is the imprint of <a href="https://www.joelhamilton.com" target="_blank" rel="noopener">Joel Hamilton</a> —
            author, homeschooling father, and founder of <a href="https://www.thenarrowmarch.com" target="_blank" rel="noopener">The Narrow March</a>.
          </p>
          <p>
            We publish books that sharpen, convict, and equip — not books that sit unread on a shelf.
            From daily devotionals to classic literature adaptations to homeschool curriculum,
            everything under this lamp is written to be used, not just owned.
          </p>
          <p>
            Our Classics line brings great literature to every reading level — because the books that shaped civilization
            deserve better than a dusty shelf and a vague memory from high school.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <p class="footer-name">Lamp & Light Publishing</p>
            <p class="footer-tagline">"Your word is a lamp to my feet<br/>and a light to my path."</p>
          </div>
          <div class="footer-nav">
            <h4>Links</h4>
            <a href="https://www.joelhamilton.com" target="_blank" rel="noopener">Joel Hamilton</a>
            <a href="https://www.thenarrowmarch.com" target="_blank" rel="noopener">The Narrow March</a>
            <a href="https://www.donenegotiating.com" target="_blank" rel="noopener">Done Negotiating</a>
          </div>
          <div class="footer-nav">
            <h4>Connect</h4>
            <a href="https://www.instagram.com/joeldhamilton" target="_blank" rel="noopener">Instagram</a>
            <a href="https://x.com/joelhamilton" target="_blank" rel="noopener">X</a>
            <a href="https://www.youtube.com/@joeldhamilton" target="_blank" rel="noopener">YouTube</a>
          </div>
        </div>
        <div class="footer-divider"></div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Lamp & Light Publishing. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      toggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

  </body>
</html>

<style>
  /* ===== Reset & Variables ===== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --font-heading: 'Cormorant Garamond', serif;
    --font-body: 'Source Serif 4', serif;
  }

  [data-theme="light"] {
    --bg: #f5f0e8;
    --bg-alt: #ebe5d9;
    --text: #2c2417;
    --text-muted: #6b5d4d;
    --accent: #b8860b;
    --accent-hover: #d4a017;
    --accent-glow: rgba(184, 134, 11, 0.12);
    --border: #d4c9b8;
    --card-bg: #faf6ef;
    --card-shadow: 0 4px 20px rgba(44, 36, 23, 0.06);
    --nav-bg: rgba(245, 240, 232, 0.95);
    --lamp-glow: rgba(255, 180, 50, 0.15);
  }

  [data-theme="dark"] {
    --bg: #1a1510;
    --bg-alt: #14100c;
    --text: #e8e0d4;
    --text-muted: #9a8d7c;
    --accent: #d4a017;
    --accent-hover: #e8b830;
    --accent-glow: rgba(212, 160, 23, 0.12);
    --border: #2e271e;
    --card-bg: #1e1914;
    --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    --nav-bg: rgba(26, 21, 16, 0.95);
    --lamp-glow: rgba(255, 180, 50, 0.08);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
    transition: background 0.3s, color 0.3s;
  }

  a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
  a:hover { color: var(--accent-hover); }

  h1, h2, h3, h4 { font-family: var(--font-heading); line-height: 1.2; }

  img { max-width: 100%; height: auto; }

  /* ===== Nav ===== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--nav-bg); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 0.75rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-brand {
    font-family: var(--font-heading); font-size: 1.2rem; font-weight: 700;
    color: var(--text); display: flex; align-items: center; gap: 0.6rem;
  }
  .nav-icon {
    width: 30px; height: 30px; border-radius: 50%; object-fit: cover;
  }
  .nav-brand:hover { color: var(--accent); }
  .nav-right { display: flex; align-items: center; gap: 1.75rem; }
  .nav-right a {
    color: var(--text-muted); font-size: 0.85rem; font-weight: 500;
    letter-spacing: 0.04em;
  }
  .nav-right a:hover { color: var(--accent); }

  .theme-toggle {
    background: none; border: 1px solid var(--border); border-radius: 50%;
    width: 34px; height: 34px; cursor: pointer; display: flex;
    align-items: center; justify-content: center; font-size: 1rem; color: var(--text);
    transition: border-color 0.2s;
  }
  .theme-toggle:hover { border-color: var(--accent); }
  [data-theme="light"] .moon { display: none; }
  [data-theme="dark"] .sun { display: none; }

  /* ===== Hero ===== */
  .hero {
    padding: 12rem 2rem 6rem;
    text-align: center;
    background: radial-gradient(ellipse at center top, var(--lamp-glow), transparent 60%);
  }
  .hero-inner { max-width: 700px; margin: 0 auto; }
  .hero-lamp {
    font-size: 3rem; margin-bottom: 1.5rem;
    filter: drop-shadow(0 0 20px rgba(255, 180, 50, 0.4));
  }
  .hero-label {
    font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 1rem; font-family: var(--font-body);
  }
  .hero h1 {
    font-size: 3.5rem; font-weight: 700; letter-spacing: 0.02em;
    margin-bottom: 1.5rem; color: var(--text);
  }
  .hero-line { width: 60px; height: 2px; background: var(--accent); margin: 0 auto 2rem; }
  .hero-tagline {
    font-style: italic; font-size: 1.15rem; color: var(--text-muted); line-height: 1.8;
  }
  .hero-cite {
    font-size: 0.9rem; color: var(--accent); font-style: normal;
  }

  /* ===== Sections ===== */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .section { padding: 6rem 0; }
  .section-alt { background: var(--bg-alt); }
  .section-label {
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); font-weight: 600; margin-bottom: 0.5rem;
  }
  .section-title { font-size: 2.2rem; margin-bottom: 0.5rem; }
  .section-line { width: 60px; height: 2px; background: var(--accent); margin-bottom: 2.5rem; }

  /* ===== Original Books ===== */
  .books-grid { display: flex; flex-direction: column; gap: 2.5rem; }

  .book-card {
    display: grid; grid-template-columns: 180px 1fr; gap: 2.5rem; align-items: start;
    background: var(--card-bg); border: 1px solid var(--border); padding: 2rem;
    box-shadow: var(--card-shadow); transition: transform 0.25s, box-shadow 0.25s;
    color: var(--text);
  }
  .book-card:hover { transform: translateY(-2px); color: var(--text); }

  .book-cover img {
    width: 100%; box-shadow: 0 6px 24px rgba(0,0,0,0.2); border: 1px solid var(--border);
  }
  .book-info h3 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .book-subtitle {
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--accent); font-weight: 600; margin-bottom: 1rem;
  }
  .book-info p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem; }
  .book-link { color: var(--accent); font-weight: 600; font-size: 0.9rem; }

  /* ===== Classics ===== */
  .classics-intro {
    color: var(--text-muted); font-size: 1.05rem; line-height: 1.9;
    max-width: 700px; margin-bottom: 3rem;
  }
  .series-title {
    font-size: 1.8rem; margin-bottom: 2rem;
  }
  .series-author {
    font-weight: 400; font-size: 1rem; color: var(--text-muted);
    font-style: italic; margin-left: 0.5rem;
  }

  .classics-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 3rem;
  }
  .classic-card {
    background: var(--card-bg); border: 1px solid var(--border); padding: 1.5rem;
    text-align: center; box-shadow: var(--card-shadow);
    transition: transform 0.25s; color: var(--text); display: block;
  }
  .classic-card:hover { transform: translateY(-2px); color: var(--text); }
  .classic-card img {
    width: 100%; max-width: 200px; margin: 0 auto 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .classic-card h4 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .classic-card p { color: var(--text-muted); font-size: 0.85rem; }

  .workbooks-heading {
    font-size: 1.3rem; margin-bottom: 1.5rem; color: var(--text-muted);
  }
  .workbooks-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
  }
  .workbook-card {
    background: var(--card-bg); border: 1px solid var(--border); padding: 1.5rem;
    text-align: center; box-shadow: var(--card-shadow);
    transition: transform 0.25s; color: var(--text); display: block;
  }
  .workbook-card:hover { transform: translateY(-2px); color: var(--text); }
  .workbook-card img {
    width: 100%; max-width: 180px; margin: 0 auto 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .workbook-card h4 { font-size: 1rem; margin-bottom: 0.25rem; }
  .workbook-card p { color: var(--text-muted); font-size: 0.85rem; }

  /* ===== About ===== */
  .about-content { max-width: 700px; }
  .about-content h2 { font-size: 2rem; margin-bottom: 1.5rem; }
  .about-content p { color: var(--text-muted); font-size: 1.05rem; line-height: 1.9; margin-bottom: 1.25rem; }

  /* ===== Footer ===== */
  .footer {
    background: var(--bg-alt); border-top: 1px solid var(--border);
    padding: 4rem 2rem 2rem;
  }
  .footer-inner { max-width: 1100px; margin: 0 auto; }
  .footer-top {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 2rem;
  }
  .footer-name {
    font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700;
    margin-bottom: 0.75rem; color: var(--text);
  }
  .footer-tagline { font-style: italic; color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; }
  .footer-nav h4 {
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text-muted); margin-bottom: 1rem; font-family: var(--font-body); font-weight: 600;
  }
  .footer-nav a { display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.6rem; }
  .footer-nav a:hover { color: var(--accent); }
  .footer-divider { height: 1px; background: var(--border); margin-bottom: 1.5rem; }
  .footer-copy { font-size: 0.75rem; color: var(--text-muted); text-align: center; }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero h1 { font-size: 2.5rem; }
    .book-card { grid-template-columns: 130px 1fr; gap: 1.5rem; }
    .classics-grid, .workbooks-grid { grid-template-columns: 1fr 1fr; }
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
    .nav-right a { display: none; }
  }

  @media (max-width: 480px) {
    .classics-grid, .workbooks-grid { grid-template-columns: 1fr; }
  }
</style>
